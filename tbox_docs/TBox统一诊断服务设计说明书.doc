</tr>
<tr>
<td style="padding:6px 10px">0xF1A0</td>
<td style="padding:6px 10px">SystemTime</td>
<td style="padding:6px 10px">Read</td>
<td style="padding:6px 10px">默认</td>
<td style="padding:6px 10px">UTC 时间 (来自 Time Sync)</td>
</tr>
<tr>
<td style="padding:6px 10px">0xF1A1</td>
