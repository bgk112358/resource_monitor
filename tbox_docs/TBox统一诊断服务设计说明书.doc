<td style="padding:6px 10px">IPC → PKCS#11</td>
</tr>
<tr>
<td style="padding:6px 10px">程序烧录</td>
<td style="padding:6px 10px">`storage.emmc`</td>
<td style="padding:6px 10px">OTA Agent</td>
