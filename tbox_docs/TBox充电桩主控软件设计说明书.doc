</tr>
<tr>
<td style="padding:6px 10px">本地鉴权白名单</td>
<td style="padding:6px 10px">`storage.emmc`</td>
<td style="padding:6px 10px">—</td>
<td style="padding:6px 10px">`/dev/mmcblk0` (ext4)</td>
</tr>
<tr>
<td style="padding:6px 10px">OTA 升级</td>
<td style="padding:6px 10px">`net.*`, `storage.*`</td>
