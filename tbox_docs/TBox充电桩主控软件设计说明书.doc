<td style="padding:6px 10px">IIO 子系统</td>
<td style="padding:6px 10px">`/sys/bus/iio/`</td>
</tr>
<tr>
<td style="padding:6px 10px">风扇/PTC 控制</td>
<td style="padding:6px 10px">`gpio`, `pwm`</td>
<td style="padding:6px 10px">直接控制</td>
<td style="padding:6px 10px">`/sys/class/pwm/`</td>
</tr>
<tr>
<td style="padding:6px 10px">故障录波存储</td>
